# ------------------------------
# OS / Editor noise
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

.vscode/
.idea/

# ------------------------------
# Git / logs / temp
# ------------------------------
*.log
logs/
*.tmp
*.temp

# ------------------------------
# Python (global)
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# Test / lint / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Python env files
.env
.env.*
!.env.example

# ------------------------------
# API (FastAPI / Alembic)
# ------------------------------
app/api/.venv/
app/api/.python-version

# Alembic generates pyc too (already covered), but keep migrations tracked
# Do NOT ignore: app/api/alembic/versions/*.py

# ------------------------------
# Service / batch (Python)
# ------------------------------
app/svc/.venv/
app/svc/.python-version

# Local inbox artifacts for image processing
app/svc/inbox/*
!app/svc/inbox/.gitkeep

# ------------------------------
# React / Node
# ------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Build outputs
app/web/dist/
app/web/.vite/
*.tsbuildinfo

# Frontend env files
app/web/.env
app/web/.env.*
!app/web/.env.example

# ------------------------------
# Docker / containers
# ------------------------------
*.pid
*.seed

# Local docker overrides
docker-compose.override.yml

# ------------------------------
# Terraform / Infra
# ------------------------------
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ------------------------------
# AWS / cloud local creds (never commit)
# ------------------------------
.aws/

# ------------------------------
# Local project data
# ------------------------------
data/
cache/
